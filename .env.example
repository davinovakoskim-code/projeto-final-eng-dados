# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=troque_aqui
POSTGRES_DB=origem
# ATENÇÃO: para usar esta opção, ajuste as variáveis de conexão
# no generate_data.py para ler POSTGRES_USER, POSTGRES_PASSWORD
# e POSTGRES_DB em vez de DB_USER, DB_PASSWORD e DB_NAME.

# ============================================================
# OPÇÃO 2: Supabase (PostgreSQL na nuvem) — recomendado
# ============================================================
DB_HOST=troque_aqui
DB_PORT=5432
DB_NAME=postgres
DB_USER=troque_aqui
DB_PASSWORD=troque_aqui

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque_aqui
# Bucket da camada landing (opcional; padrao: landing)
MINIO_BUCKET=landing
# Defina como true apenas se o MinIO estiver atras de HTTPS (opcional; padrao: false)
MINIO_SECURE=false

# Spark / s3a
# Dentro do Docker: minio:9000 | Fora do Docker: localhost:9000
MINIO_ENDPOINT=minio:9000

# Gold bucket (opcional; padrao: gold)
MINIO_GOLD_BUCKET=gold

# Metabase (http://localhost:3000)
# Nao requer variaveis adicionais — usa POSTGRES_* acima para MB_DB_*
